# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/lnkpi?schema=public"

# JWT
JWT_SECRET="change-me-in-production"
JWT_EXPIRES_IN="7d"

# BYOK encryption (32-byte random key, base64 — e.g. openssl rand -base64 32)
BYOK_ENCRYPTION_KEY_V1=""

# Server
PORT=3001
CORS_ORIGIN="http://localhost:5173,https://*.vercel.app"
API_PUBLIC_URL="http://localhost:3001"

# Web (Vercel / 本地构建)
# 本地 dev 留空即可（走 Vite proxy /api）
# Vercel 生产推荐 /api（由 vercel.json rewrite 到 CVM）；勿在 HTTPS 页面直连 http://IP
# VITE_API_BASE_URL=/api

# Auth SMS（未接入短信前保持 fixed）
AUTH_SMS_MODE=fixed
AUTH_FIXED_CODE=123456

# AI Providers (optional — without key, RuleBasedAgent + placeholder images are used)
OPENAI_API_KEY=""
OPENAI_BASE_URL="https://api.openai.com/v1"
OPENAI_CHAT_MODEL="gpt-4o"
OPENAI_IMAGE_MODEL="dall-e-3"

# Agent Runtime (Nest internal canvas tools + optional LangGraph runtime)
AGENT_RUNTIME_SERVICE_TOKEN=""
AGENT_RUNTIME_URL=""

