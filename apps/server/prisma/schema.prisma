generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String    @id @default(cuid())
  phone     String    @unique
  nickname  String
  avatar    String?
  createdAt DateTime  @default(now())
  sessions  Session[]
  works     Work[]
}

model Session {
  id         String   @id @default(cuid())
  title      String   @default("未命名画布")
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  canvasData String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  works      Work[]
}

model Work {
  id         String   @id @default(cuid())
  title      String
  coverUrl   String
  type       String   @default("canvas")
  authorId   String
  author     User     @relation(fields: [authorId], references: [id])
  sessionId  String?
  session    Session? @relation(fields: [sessionId], references: [id])
  likes      Int      @default(0)
  views      Int      @default(0)
  category   String?
  createdAt  DateTime @default(now())
}

model VerificationCode {
  id        String   @id @default(cuid())
  phone     String
  code      String
  expiresAt DateTime
  createdAt DateTime @default(now())
}
