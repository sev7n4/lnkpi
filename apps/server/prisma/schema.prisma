generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id         String             @id @default(cuid())
  phone      String             @unique
  nickname   String
  avatar     String?
  points     Int                @default(1000)
  membership String             @default("free")
  createdAt  DateTime           @default(now())
  sessions   Session[]
  works      Work[]
  stories    Story[]
  generations GenerationRecord[]
  pointTransactions PointTransaction[]
}

model PointTransaction {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  amount    Int
  reason    String
  createdAt DateTime @default(now())
}

model GenerationRecord {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String
  prompt    String
  model     String?
  url       String?
  status    String   @default("completed")
  metadata  String?
  createdAt DateTime @default(now())
}

model Story {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title        String
  synopsis     String   @default("")
  sessionId    String?
  session      Session? @relation(fields: [sessionId], references: [id])
  status       String   @default("draft")
  episodeCount Int      @default(1)
  coverUrl     String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Session {
  id            String         @id @default(cuid())
  title         String         @default("未命名画布")
  userId        String
  user          User           @relation(fields: [userId], references: [id])
  canvasData    String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  works         Work[]
  shots         Shot[]
  agentMessages AgentMessage[]
  stories       Story[]
}

model Shot {
  id        String     @id @default(cuid())
  sessionId String
  session   Session    @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  title     String     @default("未命名分镜")
  prompt    String     @default("")
  order     Int        @default(0)
  status    String     @default("draft")
  positionX Float      @default(0)
  positionY Float      @default(0)
  materials Material[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model Material {
  id        String   @id @default(cuid())
  shotId    String
  shot      Shot     @relation(fields: [shotId], references: [id], onDelete: Cascade)
  type      String   @default("image")
  url       String?
  thumbnail String?
  prompt    String?
  status    String   @default("idle")
  order     Int      @default(0)
  createdAt DateTime @default(now())
}

model AgentMessage {
  id        String   @id @default(cuid())
  sessionId String
  session   Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  role      String
  content   String
  toolCalls String?
  createdAt DateTime @default(now())
}

model Work {
  id         String   @id @default(cuid())
  title      String
  coverUrl   String
  type       String   @default("canvas")
  authorId   String
  author     User     @relation(fields: [authorId], references: [id])
  sessionId  String?
  session    Session? @relation(fields: [sessionId], references: [id])
  likes      Int      @default(0)
  views      Int      @default(0)
  category   String?
  createdAt  DateTime @default(now())
}

model VerificationCode {
  id        String   @id @default(cuid())
  phone     String
  code      String
  expiresAt DateTime
  createdAt DateTime @default(now())
}
