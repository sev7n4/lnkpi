# Agent Runtime（生产）— 轻量镜像，仅内网被 Nest 调用，勿对公网暴露 8000
FROM python:3.11-slim

WORKDIR /app

RUN apt-get update && apt-get install -y --no-install-recommends \
    curl \
  && rm -rf /var/lib/apt/lists/*

COPY services/agent-runtime/pyproject.toml ./
COPY services/agent-runtime/app ./app
COPY services/agent-runtime/skills ./skills

# pyproject 无 setuptools 包声明时，直接按依赖安装即可
RUN pip install --no-cache-dir \
    "fastapi>=0.115" \
    "uvicorn[standard]>=0.32" \
    "langgraph>=0.2" \
    "langchain-openai>=0.2" \
    "httpx>=0.27" \
    "pyyaml>=6.0" \
    "pydantic-settings>=2.0"

ENV LNKPI_SKILLS_DIR=/app/skills
ENV PYTHONPATH=/app
EXPOSE 8000

HEALTHCHECK --interval=30s --timeout=5s --retries=3 --start-period=20s \
  CMD curl -fsS http://127.0.0.1:8000/health || exit 1

CMD ["uvicorn", "app.main:app", "--host", "0.0.0.0", "--port", "8000"]
