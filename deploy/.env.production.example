# 复制到 /opt/lnkpi/.env（勿提交 Git）
# cp deploy/.env.production.example .env

# --- 公网访问（按实际 IP / 域名修改）---
# Vercel 前端会通过此 API 地址访问后端
API_PUBLIC_URL=http://119.29.173.89:5100
CORS_ORIGIN=http://localhost:5173,https://*.vercel.app

# --- API 核心（必填，请替换占位符）---
PORT=3001
JWT_SECRET=请替换为随机长字符串
JWT_EXPIRES_IN=7d
# BYOK 服务端加密主密钥（32 字节随机，base64 — 例：openssl rand -base64 32）
BYOK_ENCRYPTION_KEY_V1=
DATABASE_URL=file:/app/apps/server/data/lnkpi.db

# --- 登录验证码（未接入短信前保持 fixed）---
AUTH_SMS_MODE=fixed
AUTH_FIXED_CODE=123456

# --- AI Providers（可选；无 key 时使用 RuleBasedAgent + 占位图）---
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_CHAT_MODEL=gpt-4o
OPENAI_IMAGE_MODEL=dall-e-3
OPENAI_VIDEO_MODEL=agnes-video-v2.0
# Agnes 视频轮询根路径（非 /v1）
AGNES_API_ROOT=https://apihub.agnes-ai.com

# Agnes 示例（勿提交真实 Key）：
# OPENAI_BASE_URL=https://apihub.agnes-ai.com/v1
# OPENAI_CHAT_MODEL=agnes-2.0-flash
# OPENAI_IMAGE_MODEL=agnes-image-2.1-flash
# OPENAI_VIDEO_MODEL=agnes-video-v2.0

# --- Agent Runtime（LangGraph；详见 deploy/AGENT_RUNTIME_PRODUCTION.md）---
# 服务互信（不是出图 BYOK Key）。两边 token 必须相同。
AGENT_RUNTIME_SERVICE_TOKEN=
# Compose 同网络：http://lnkpi-agent-runtime:8000
# systemd 本机：http://127.0.0.1:8000
# 留空 = Nest 回退旧 CanvasAgent
AGENT_RUNTIME_URL=http://lnkpi-agent-runtime:8000

# Runtime → Nest（Compose 内网名；systemd 用 http://127.0.0.1:5100/api）
LNKPI_NEST_BASE_URL=http://lnkpi-api:3001/api
LNKPI_NEST_SERVICE_TOKEN=
# 规划 LLM（一期独立；出图仍走 Studio/BYOK）
LNKPI_OPENAI_API_KEY=
LNKPI_OPENAI_BASE_URL=https://api.openai.com/v1
# 规划模型名；可与 Nest OPENAI_CHAT_MODEL 对齐（如 agnes-2.0-flash）
LNKPI_OPENAI_CHAT_MODEL=
LNKPI_IMAGE_GEN_CONCURRENCY=3
LNKPI_IMAGE_GEN_TIMEOUT_SEC=180
