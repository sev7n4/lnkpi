# 复制到 /opt/lnkpi/.env（勿提交 Git）
# cp deploy/.env.production.example .env

# --- 公网访问（按实际 IP / 域名修改）---
# Vercel 前端会通过此 API 地址访问后端
API_PUBLIC_URL=http://119.29.173.89:5100
CORS_ORIGIN=http://localhost:5173,https://*.vercel.app

# --- API 核心（必填，请替换占位符）---
PORT=3001
JWT_SECRET=请替换为随机长字符串
JWT_EXPIRES_IN=7d
DATABASE_URL=file:/app/apps/server/data/lnkpi.db

# --- AI Providers（可选；无 key 时使用 RuleBasedAgent + 占位图）---
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_CHAT_MODEL=gpt-4o
OPENAI_IMAGE_MODEL=dall-e-3
