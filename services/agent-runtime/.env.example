# Nest API base (must include /api prefix for internal canvas tools)
LNKPI_NEST_BASE_URL=http://127.0.0.1:3000/api
# Must match Nest AGENT_RUNTIME_SERVICE_TOKEN
LNKPI_NEST_SERVICE_TOKEN=dev-token

LNKPI_SKILLS_DIR=skills
LNKPI_OPENAI_API_KEY=
LNKPI_OPENAI_BASE_URL=https://api.openai.com/v1
LNKPI_IMAGE_GEN_CONCURRENCY=3
LNKPI_IMAGE_GEN_TIMEOUT_SEC=180
